@startuml
left to right direction

actor "User" as U

rectangle "COLORS Web Application" {
  usecase "Login" as UC1
  usecase "Add Color" as UC2
  usecase "Search Colors" as UC3
  usecase "View Color Results" as UC4
  usecase "Logout" as UC5
}

U --> UC1
U --> UC2
U --> UC3
U --> UC5
UC3 .> UC4 : <<include>>

note right of UC1
  Password is hashed
end note

note right of UC2
  Requires active session
  (userId from cookie)
end note
@enduml
